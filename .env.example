# Runtime profile
APP_ENV=development

# Required security settings
# Generate strong values before running the app:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
SALT=replace-with-a-strong-random-salt-at-least-16-chars

# First admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_ROLE=admin

# Session and password reset
TOKEN_EXPIRY_HOURS=1
MIN_PASSWORD_LENGTH=8
PASSWORD_RESET_MAX_PER_HOUR=5
ENABLE_ADMIN_2FA=false

# Face recognition
MODEL_NAME=ArcFace
DETECTOR_BACKEND=retinaface
EMBEDDING_SIZE=512
RECOGNITION_THRESHOLD=0.5
RECOGNITION_MARGIN=0.08
ALLOW_SKIP_DETECTION_FALLBACK=false

# Biometric cache policy
# Keep disabled unless you need performance caching. When enabled, encryption is required.
BIOMETRIC_CACHE_ENABLED=false
# Generate only if BIOMETRIC_CACHE_ENABLED=true:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BIOMETRIC_CACHE_ENCRYPTION_KEY=
BIOMETRIC_CACHE_FILE=embeddings.cache

# Mask detection
MASK_FRAME_SKIP=2
MASK_BLOCK_UNCERTAIN=true
ATTENDANCE_MASK_CHECK_ENABLED=true
MASK_USE_YOLO=true
MASK_YOLO_MODEL=yolov8s-worldv2.pt
MASK_YOLO_DEVICE=cpu
MASK_YOLO_CONF_MASK=0.22
MASK_YOLO_CONF_NOMASK=0.32
YOLO_CLASS_MASK_TEXT=person wearing a medical face mask covering nose and mouth
YOLO_CLASS_NOMASK_TEXT=human face without mask nose and mouth visible
